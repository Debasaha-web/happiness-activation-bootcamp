# ─────────────────────────────────────────────────────────────
#  Happiness Activation Bootcamp — environment variables
#  Copy to .env.local for local dev, and add the same keys to
#  Vercel → Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Public base URL of the app (no trailing slash).
#   local:  http://localhost:3000
#   prod:   https://activate-happiness.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (NEW project — do not reuse any existing one) ──
# Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Bypasses RLS for trusted writes. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Auth (magic links) ──
# Secret used to sign magic-link + session JWTs. Generate a long random string:
#   openssl rand -base64 48
AUTH_SECRET=replace-with-a-long-random-secret

# ── Resend (magic-link email + Day-7 report delivery) ──
# https://resend.com → API Keys
RESEND_API_KEY=re_your_resend_key
# A verified sender on your domain, e.g. "Happiness Activation <hello@yourdomain.com>"
EMAIL_FROM=Happiness Activation <hello@yourdomain.com>

# ── Anthropic (Day-7 report) ──
# https://console.anthropic.com → API Keys. Server-side only.
ANTHROPIC_API_KEY=sk-ant-your-key
